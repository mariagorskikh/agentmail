{
  "name": "agentmail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "concurrently -k -n server,worker -c blue,green \"npm run dev:server\" \"npm run dev:worker\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start:server": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "migrate": "node-pg-migrate up -m migrations -d DATABASE_URL --tsconfig tsconfig.json",
    "migrate:down": "node-pg-migrate down -m migrations -d DATABASE_URL",
    "dev:inject": "tsx scripts/inject.ts",
    "demo": "tsx scripts/demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^9.1.3",
    "bullmq": "^5.34.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "postmark": "^4.0.5",
    "sanitize-html": "^2.13.1",
    "ulid": "^2.3.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.1",
    "@types/sanitize-html": "^2.13.0",
    "concurrently": "^9.1.0",
    "node-pg-migrate": "^7.8.0",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
