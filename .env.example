# Server
NODE_ENV=development
PORT=3000
WEB_PORT=3001
API_TOKEN=change-me-to-a-long-random-string
OWNER_PASSWORD=change-me-or-leave-blank-to-disable-login

# Owner identity
OWNER_EMAIL=you@yourdomain.com
OWNER_NAME=Your Name

# Postgres
DATABASE_URL=postgres://app:app@localhost:5432/agentmail

# Redis
REDIS_URL=redis://localhost:6379

# Postmark
POSTMARK_SERVER_TOKEN=
POSTMARK_WEBHOOK_TOKEN=
POSTMARK_INBOUND_EMAIL=
POSTMARK_OUTBOUND_STREAM=outbound

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL_CLASSIFIER=claude-haiku-4-5-20251001
CLAUDE_MODEL_DRAFTER=claude-opus-4-7

# Behavior
DELAYED_SEND_SECONDS=60
MAX_OUTBOUND_PER_HOUR=30
MAX_OUTBOUND_PER_DAY=200
